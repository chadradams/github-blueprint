# Copy this file to .env.local and fill in your values
# Run `terraform output env_local_snippet` after deploy for auto-populated values

# Azure AI Foundry / Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Cosmos DB (blueprint persistence)
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key

# GitHub OAuth App — create at github.com/settings/developers
# Callback URL: http://localhost:3000/api/github/callback  (dev)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# JWT session signing secret — minimum 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your-32-char-minimum-random-secret
